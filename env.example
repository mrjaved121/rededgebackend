PORT=3000
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=700d
UPLOAD_DIR=uploads

# Comma-separated browser origins allowed by CORS. Leave empty to allow all origins.
# Mobile apps are always allowed regardless of this setting.
CORS_ORIGINS=https://your-domain.com

# Set to 'true' ONLY when intentionally running the seed script (it wipes all data)
ALLOW_SEED=

# ImageKit.io credentials — get from https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-id
